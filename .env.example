# Supabase — get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe — get from Stripe Dashboard > Developers > API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe price ID — create a monthly recurring price in Stripe Dashboard
VITE_STRIPE_PRO_PRICE_ID=price_your-price-id

# Anthropic — get from console.anthropic.com
# NOTE: For production, proxy this through your backend (Supabase Edge Function)
# Never expose your secret key in a frontend build
VITE_ANTHROPIC_API_KEY=sk-ant-your-key

# App URL (used for Stripe redirect)
VITE_APP_URL=http://localhost:5173
